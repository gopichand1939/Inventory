{
  "name": "ration-inventory-app",
  "version": "1.0.0",
  "description": "Windows Desktop Ration Inventory Management System",
  "main": "main.js",
  "scripts": {
    "dev:frontend": "npm run dev --prefix Frontend",
    "dev:backend": "node Backend/server.js",
    "build:frontend": "npm run build --prefix Frontend",
    "start": "electron .",
    "dev": "concurrently \"npm run dev:frontend\" \"wait-on http://localhost:5180 && electron .\"",
    "package": "npm run build:frontend && electron-builder build --win"
  },
  "dependencies": {
    "bcryptjs": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ration.inventory",
    "productName": "Ration Inventory",
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "preload.js",
      "Backend/**/*",
      "Frontend/dist/**/*",
      "node_modules/**/*"
    ],
    "asar": true
  }
}
